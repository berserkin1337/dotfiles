{
  "settings": {
    "toolPrefix": "server",
    "idleTimeout": 10,
    "requestTimeoutMs": 60000
  },
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--no-usage-statistics",
        "--slim",
        "--screenshotFormat=jpeg",
        "--screenshotMaxWidth=1280"
      ],
      "lifecycle": "lazy",
      "idleTimeout": 10,
      "requestTimeoutMs": 60000
    }
  }
}
